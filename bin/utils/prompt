#!/bin/bash

autoload -Uz vcs_info
autoload -Uz add-zsh-hook

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats '%b'

COLOR_PURPLE='%B%F{#a5b4fc}'
COLOR_GREEN='%F{#008700}'
COLOR_GREEN_LIGHT='%F{#00d700}'
COLOR_RED='%F{#ff5f5f}'
COLOR_RESET='%f%b'
COLOR_GRAY='%F{#52525b}'

update_git_prompt_info() {
    vcs_info
    if [[ -n "$vcs_info_msg_0_" ]]; then
        ETX_GIT_PROMPT="${COLOR_RESET}"
         if [[ -n $(command git status --porcelain 2>/dev/null | head -n 1) ]]; then
            ETX_GIT_PROMPT=" ${COLOR_RED}✘${COLOR_RESET}"
        fi
        GIT_PROMPT=" ${COLOR_PURPLE}git(${COLOR_GREEN}${vcs_info_msg_0_}${COLOR_PURPLE})${ETX_GIT_PROMPT}"
    else
        GIT_PROMPT=""
    fi
}

add-zsh-hook precmd update_git_prompt_info
setopt prompt_subst

# Prompt
PROMPT='${GIT_PROMPT} ${COLOR_GREEN_LIGHT}%B>%b${COLOR_RESET} '
RPROMPT='🐾 ${COLOR_GRAY}%*'
