#!/bin/bash

function gitbranch() {
    # 1. Kiểm tra xem có đang ở trong thư mục Git không
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Not a git repository."
        return 1
    fi

    # 2. Lấy thông tin trong 1 lần duy nhất
    local current=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    local merged_branches=$(git branch --merged "$current" 2>/dev/null | sed 's/^[ *]*//' | tr '\n' ' ')

    # 3. Lấy top 10 mới nhất và pipe thẳng vào awk
    git for-each-ref --sort=-committerdate refs/heads/ --format='%(refname:short)' | head -n 10 | \
    awk -v curr="$current" -v merged_data="$merged_branches" '
        BEGIN {
            split(merged_data, m_arr, " ")
            for (i in m_arr) {
                if (m_arr[i] != "") merged_map[m_arr[i]] = 1
            }

            count = 0
            w_status = 6
            w_name = 4

            GREEN = "\033[0;32m"
            RESET = "\033[0m"
        }

        {
            branch = $1
            count++
            names[count] = branch

            # Phân loại Status
            if (branch == curr) {
                status[count] = "Current"
                colors[count] = ""
            } else if (branch in merged_map) {
                status[count] = "Merged"
                colors[count] = GREEN
            } else {
                status[count] = "Active"
                colors[count] = ""
            }

            if (length(status[count]) > w_status) w_status = length(status[count])
            if (length(names[count]) > w_name) w_name = length(names[count])
        }

        END {
            if (count == 0) {
                print "No branches found."
                exit
            }

            # Hàm vẽ viền ngang (+---+---+)
            border = "+"
            for(i=0; i<w_status+2; i++) border = border "-"
            border = border "+"
            for(i=0; i<w_name+2; i++) border = border "-"
            border = border "+"

            # In Header
            print border
            printf "| %-*s | %-*s |\n", w_status, "STATUS", w_name, "NAME"
            print border

            # In Dữ liệu
            for (i=1; i<=count; i++) {
                status_padded = sprintf("%-*s", w_status, status[i])
                printf "| %s%s%s | %-*s |\n", colors[i], status_padded, RESET, w_name, names[i]
            }

            # In Footer
            print border
        }
    '
}
